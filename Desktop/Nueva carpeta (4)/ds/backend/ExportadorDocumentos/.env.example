# === JWT Configuration ===
JWT__SecretKey=CHANGE_ME_USE_A_STRONG_SECRET_KEY
JWT__Issuer=ExportadorDocumentos
JWT__Audience=ExportadorDocumentos
JWT__ExpirationHours=1

# === PostgreSQL (Neon) ===
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# === CORS ===
CORS__AllowedOrigins=http://localhost:5173
